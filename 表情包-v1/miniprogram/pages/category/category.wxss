.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.search-bar {
  padding: 20rpx 30rpx;
  background: #fff;
}

.search-input {
  background: #f5f5f5;
  border-radius: 30rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
}

.content {
  flex: 1;
  height: calc(100vh - 120rpx);
}

.section {
  background: #fff;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.section-title {
  margin-bottom: 20rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.cat-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.cat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #f5f5f5;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  min-width: 140rpx;
  border: 2rpx solid transparent;
}

.cat-item.active {
  background: #E8F0FE;
  border-color: #4A90D9;
}

.cat-icon {
  font-size: 40rpx;
}

.cat-name {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-tag {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.meme-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.meme-item {
  border-radius: 20rpx;
  overflow: hidden;
  background: #f8f8f8;
  position: relative;
}

.meme-like {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(0,0,0,0.35);
  border-radius: 20rpx;
  padding: 6rpx 14rpx;
  z-index: 3;
}

.meme-like-icon {
  font-size: 22rpx;
  color: #bbb;
}

.meme-like.liked .meme-like-icon {
  color: #ff3b5c;
}

.meme-like-num {
  font-size: 20rpx;
  color: rgba(255,255,255,0.85);
  font-weight: 500;
}

.meme-like.liked .meme-like-num {
  color: #ff3b5c;
}

.rank-item-like {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  background: rgba(0,0,0,0.35);
  border-radius: 50%;
  font-size: 24rpx;
  color: #bbb;
  flex-shrink: 0;
}

.rank-item-like.liked {
  color: #ff3b5c;
}

.meme-image {
  width: 100%;
  height: 300rpx;
  background: #eee;
}

.meme-info {
  padding: 16rpx;
}

.meme-desc {
  font-size: 24rpx;
  color: #666;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.empty-state {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

.hot-card .cat-icon {
  font-size: 40rpx;
}

.rank-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx;
  background: #fafafa;
  border-radius: 16rpx;
}

.rank-num {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 800;
  color: #999;
  background: #eee;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.rank-num.top1 {
  color: #fff;
  background: linear-gradient(135deg, #FFD700, #FFA500);
}

.rank-num.top2 {
  color: #fff;
  background: linear-gradient(135deg, #C0C0C0, #909090);
}

.rank-num.top3 {
  color: #fff;
  background: linear-gradient(135deg, #CD7F32, #A0522D);
}

.rank-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #e8e8e8;
}

.rank-info {
  flex: 1;
  min-width: 0;
}

.rank-desc {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-likes {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}
