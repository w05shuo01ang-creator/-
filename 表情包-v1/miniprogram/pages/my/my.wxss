.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.user-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 36rpx 30rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.upload-btn {
  background: rgba(255,255,255,0.25);
  color: #fff;
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.header-btns {
  display: flex;
  gap: 16rpx;
}

.admin-btn {
  background: rgba(255,255,255,0.15);
}

.tabs {
  display: flex;
  background: #fff;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #888;
  border-bottom: 4rpx solid transparent;
}

.tab.active {
  color: #4A90D9;
  border-bottom-color: #4A90D9;
}

.meme-list {
  padding: 20rpx;
}

.meme-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.meme-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.meme-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.meme-desc {
  font-size: 26rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.meme-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  align-self: flex-start;
  margin: 10rpx 0;
}

.meme-status.ok { background: #E8F5E9; color: #27ae60; }
.meme-status.wait { background: #FFF8E1; color: #f39c12; }
.meme-status.fail { background: #FFEBEE; color: #e74c3c; }

.meme-actions {
  display: flex;
  gap: 24rpx;
}

.action {
  font-size: 24rpx;
  color: #4A90D9;
}

.action.danger {
  color: #e74c3c;
}

.action.publish {
  color: #27ae60;
  font-weight: 500;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  width: 620rpx;
  max-height: 85vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  display: block;
  margin-bottom: 28rpx;
}

.preview-box {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.preview-empty {
  width: 100%;
  height: 100%;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.plus {
  font-size: 72rpx;
  color: #ccc;
}

.tag-section {
  margin-bottom: 24rpx;
}

.tag-header {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  margin-bottom: 14rpx;
}

.tag-hint {
  color: #999;
  font-size: 24rpx;
}

.tag-input-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.tag-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 24rpx;
  padding: 16rpx 22rpx;
  font-size: 26rpx;
}

.add-btn {
  background: #4A90D9;
  color: #fff;
  padding: 14rpx 26rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #E8F0FE;
  color: #4A90D9;
  padding: 10rpx 18rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
}

.tag-rm {
  font-size: 26rpx;
  color: #999;
}

.modal-btns {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  border-radius: 32rpx;
  font-size: 28rpx;
  padding: 18rpx;
}

.btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.btn.ok {
  background: #4A90D9;
  color: #fff;
}
