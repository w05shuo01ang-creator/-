.container {
  padding: 24rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.quota-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.quota-text {
  font-size: 28rpx;
  color: #333;
}

.recharge-btn {
  background: #4A90D9;
  color: #fff;
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.input-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  position: relative;
}

.prompt-input {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  border: none;
}

.char-count {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  font-size: 24rpx;
  color: #999;
}

.quick-prompts {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.prompt-item {
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #4A90D9;
}

.generate-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.generate-btn[disabled] {
  background: #ccc;
}

.result-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.result-image {
  width: 100%;
  max-height: 500rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.tags-section {
  margin-bottom: 24rpx;
}

.tags-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.tags-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.tags-hint {
  font-size: 24rpx;
  color: #999;
}

.tags-input-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tag-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
}

.add-tag-btn {
  background: #4A90D9;
  color: #fff;
  padding: 16rpx 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #E8F0FE;
  color: #4A90D9;
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.remove-btn {
  font-size: 28rpx;
  color: #999;
}

.action-btns {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  border-radius: 32rpx;
  font-size: 28rpx;
  padding: 20rpx;
}

.save-btn {
  background: #f5f5f5;
  color: #333;
}

.share-btn {
  background: #4A90D9;
  color: #fff;
}

.recharge-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.recharge-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  width: 600rpx;
}

.recharge-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  display: block;
  margin-bottom: 30rpx;
}

.package-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.package-item {
  display: flex;
  justify-content: space-between;
  padding: 24rpx;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
}

.package-item.selected {
  border-color: #4A90D9;
  background: #F5F9FF;
}

.package-count {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.package-price {
  font-size: 26rpx;
  color: #4A90D9;
}

.recharge-btns {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  border-radius: 32rpx;
  font-size: 28rpx;
  padding: 20rpx;
}

.btn.cancel {
  background: #f5f5f5;
  color: #333;
}

.btn.confirm {
  background: #4A90D9;
  color: #fff;
}
