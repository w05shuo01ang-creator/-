.card {
  overflow: hidden;
  border: 1rpx solid #e6e9ee;
  border-radius: 8rpx;
  background: #ffffff;
}

.media {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  background: #edf0f4;
}

.image {
  width: 100%;
  height: 100%;
}

.status {
  position: absolute;
  top: 14rpx;
  left: 14rpx;
  padding: 7rpx 12rpx;
  border-radius: 6rpx;
  background: rgba(24, 32, 42, 0.82);
  color: #ffffff;
  font-size: 21rpx;
}

.status-approved { background: rgba(22, 138, 85, 0.9); }
.status-rejected { background: rgba(240, 68, 88, 0.9); }

.body {
  padding: 18rpx;
}

.prompt {
  display: block;
  overflow: hidden;
  height: 40rpx;
  color: #18202a;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 40rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.tag {
  overflow: hidden;
  max-width: 180rpx;
  color: #77808c;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.like {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  gap: 6rpx;
  width: 104rpx;
  height: 48rpx;
  border: 1rpx solid transparent;
  border-radius: 6rpx;
  background: #f3f5f7;
  color: #77808c;
  font-size: 22rpx;
  box-sizing: border-box;
  transition: color 150ms ease, background-color 150ms ease, border-color 150ms ease;
}

.heart {
  display: block;
  width: 30rpx;
  height: 30rpx;
  color: #a6afb9;
  font-size: 28rpx;
  line-height: 30rpx;
  text-align: center;
  transition: color 150ms ease;
}

.is-liked {
  border-color: #ffd2d8;
  background: #fff1f3;
  color: #f04458;
}

.is-liked .heart {
  color: #f04458;
}
