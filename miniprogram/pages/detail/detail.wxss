.detail-page {
  background: #ffffff;
}

.viewer {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 720rpx;
  background: #18202a;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.viewer-hint {
  position: absolute;
  right: 24rpx;
  bottom: 22rpx;
  padding: 8rpx 12rpx;
  border-radius: 5rpx;
  background: rgba(0, 0, 0, 0.56);
  color: #ffffff;
  font-size: 21rpx;
}

.detail-body {
  padding: 34rpx 30rpx calc(50rpx + env(safe-area-inset-bottom));
}

.prompt {
  display: block;
  font-size: 38rpx;
  font-weight: 750;
  line-height: 1.45;
}

.summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
}

.date {
  color: #77808c;
  font-size: 24rpx;
}

.main-like {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  gap: 8rpx;
  width: 124rpx;
  height: 64rpx;
  border: 1rpx solid #dfe4ea;
  border-radius: 7rpx;
  background: #f7f8fa;
  color: #59636f;
  font-size: 24rpx;
  box-sizing: border-box;
  transition: color 150ms ease, background-color 150ms ease, border-color 150ms ease;
}

.heart {
  display: block;
  width: 34rpx;
  height: 34rpx;
  color: #a6afb9;
  font-size: 32rpx;
  line-height: 34rpx;
  text-align: center;
  transition: color 150ms ease;
}

.main-like.liked {
  border-color: #ffd2d8;
  background: #fff1f3;
  color: #f04458;
}

.main-like.liked .heart { color: #f04458; }

.divider {
  height: 1rpx;
  margin: 30rpx 0;
  background: #e6e9ee;
}

.tag-title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 29rpx;
  font-weight: 700;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid #dfe4ea;
  border-radius: 7rpx;
  background: #f7f8fa;
  font-size: 24rpx;
}

.tag-like {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  gap: 5rpx;
  width: 88rpx;
  height: 42rpx;
  border-radius: 5rpx;
  background: #ffffff;
  color: #77808c;
  font-size: 22rpx;
  box-sizing: border-box;
  transition: color 150ms ease, background-color 150ms ease;
}

.tag-heart {
  display: block;
  width: 26rpx;
  height: 26rpx;
  color: #a6afb9;
  line-height: 26rpx;
  text-align: center;
  transition: color 150ms ease;
}

.tag-like.liked {
  background: #fff1f3;
  color: #f04458;
}

.tag-like.liked .tag-heart { color: #f04458; }

.save-button { margin-top: 40rpx; }

.share-button {
  height: 82rpx;
  margin-top: 16rpx;
  border: 1rpx solid #dfe4ea;
  border-radius: 8rpx;
  background: #ffffff;
  color: #18202a;
  font-size: 28rpx;
  line-height: 82rpx;
}

.detail-loading {
  color: #ffffff;
  background: #18202a;
}
