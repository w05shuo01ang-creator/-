.account-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 38rpx 30rpx 30rpx;
  background: #ffffff;
}

.head-title,
.head-sub {
  display: block;
}

.head-title {
  font-size: 42rpx;
  font-weight: 750;
}

.head-sub {
  margin-top: 8rpx;
  color: #77808c;
  font-size: 24rpx;
}

.upload-button {
  height: 70rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 7rpx;
  background: #165dff;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 650;
  line-height: 70rpx;
}

.tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: 0 30rpx;
  border-bottom: 1rpx solid #e6e9ee;
  background: #ffffff;
}

.tab {
  position: relative;
  padding: 23rpx 0;
  color: #77808c;
  text-align: center;
}

.tab.active {
  color: #18202a;
  font-weight: 700;
}

.tab.active::after {
  position: absolute;
  right: 22%;
  bottom: 0;
  left: 22%;
  height: 5rpx;
  background: #165dff;
  content: '';
}

.mine-list {
  padding: 24rpx 30rpx 60rpx;
}

.mine-item {
  display: grid;
  grid-template-columns: 150rpx minmax(0, 1fr) 86rpx;
  gap: 20rpx;
  min-height: 150rpx;
  margin-bottom: 18rpx;
  padding: 18rpx;
  border: 1rpx solid #e6e9ee;
  border-radius: 8rpx;
  background: #ffffff;
}

.thumb {
  width: 150rpx;
  height: 150rpx;
  border-radius: 6rpx;
  background: #edf0f4;
}

.item-main {
  min-width: 0;
}

.item-prompt,
.item-tags,
.item-status {
  display: block;
}

.item-prompt {
  overflow: hidden;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-tags {
  overflow: hidden;
  margin-top: 11rpx;
  color: #77808c;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-status {
  margin-top: 17rpx;
  color: #77808c;
  font-size: 23rpx;
}

.status-approved { color: #168a55; }
.status-rejected { color: #f04458; }
.status-pending { color: #9b6508; }

.actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
}

.action {
  color: #59636f;
  font-size: 24rpx;
}

.action.primary { color: #165dff; }
.action.danger { color: #f04458; }

.mask {
  position: fixed;
  z-index: 20;
  inset: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(24, 32, 42, 0.52);
}

.sheet {
  width: 100%;
  max-height: 92vh;
  overflow-y: auto;
  padding: 30rpx 30rpx calc(34rpx + env(safe-area-inset-bottom));
  border-radius: 8rpx 8rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.sheet-head,
.field-head,
.tag-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sheet-title {
  font-size: 35rpx;
  font-weight: 750;
}

.sheet-close {
  padding: 8rpx 0 8rpx 24rpx;
  color: #77808c;
  font-size: 42rpx;
}

.picker {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 300rpx;
  margin: 26rpx 0;
  border: 2rpx dashed #cfd6df;
  border-radius: 8rpx;
  background: #f7f8fa;
}

.picker-image {
  width: 100%;
  height: 100%;
}

.picker-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #59636f;
}

.picker-plus {
  margin-bottom: 8rpx;
  color: #165dff;
  font-size: 55rpx;
}

.picker-hint,
.field-hint {
  margin-top: 8rpx;
  color: #929ba6;
  font-size: 21rpx;
}

.field-label {
  display: block;
  margin: 20rpx 0 12rpx;
  font-weight: 650;
}

.field {
  height: 76rpx;
  padding: 0 20rpx;
  border: 1rpx solid #dfe4ea;
  border-radius: 7rpx;
  background: #f7f8fa;
  font-size: 26rpx;
  box-sizing: border-box;
}

.field-head .field-hint { margin-top: 20rpx; }
.tag-field { flex: 1; }

.tag-add {
  margin-left: 18rpx;
  padding: 20rpx 8rpx;
  color: #165dff;
  font-weight: 650;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  min-height: 48rpx;
  margin-top: 16rpx;
}

.tag {
  padding: 10rpx 14rpx;
  border-radius: 6rpx;
  background: #edf3ff;
  color: #165dff;
  font-size: 23rpx;
}

.tag-remove { margin-left: 10rpx; }
.submit { margin-top: 28rpx; }

