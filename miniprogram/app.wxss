page {
  --ink: #18202a;
  --muted: #77808c;
  --line: #e6e9ee;
  --surface: #ffffff;
  --canvas: #f4f6f8;
  --primary: #165dff;
  --coral: #f04458;
  --green: #168a55;
  background: var(--canvas);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 34rpx 30rpx 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
}

.section-link {
  color: var(--primary);
  font-size: 25rpx;
}

.loading,
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 320rpx;
  padding: 40rpx;
  color: var(--muted);
  text-align: center;
  box-sizing: border-box;
}

.empty-title {
  margin-bottom: 12rpx;
  color: var(--ink);
  font-size: 31rpx;
  font-weight: 650;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 8rpx;
  background: var(--primary);
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 650;
  line-height: 1;
}

.primary-button[disabled] {
  background: #aebbd0;
  color: #ffffff;
}

